# Copy to .env and adjust per environment (e.g. on a remote server, use its public IP/domain).
# docker-compose.yml reads this file automatically.

# Base URL the browser uses to reach the API — must include the /api prefix.
# Baked into the web app's JS bundle at Docker build time, so changing this
# requires `docker compose build web` (not just a container restart).
NEXT_PUBLIC_API_BASE_URL=http://localhost:4001/api
