{
  "name": "loop",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run dev --workspace=apps/api",
    "dev:web": "npm run dev --workspace=apps/web",
    "build": "npm run build --workspace=packages/db && npm run build --workspace=apps/api && npm run build --workspace=apps/web",
    "db": "npm run build --workspace=packages/db",
    "seed": "npm run seed --workspace=packages/db",
    "prisma": "cd packages/db && prisma",
    "generate": "cd packages/db && prisma generate",
    "migrate": "cd packages/db && prisma migrate dev",
    "db:push": "cd packages/db && prisma db push",
    "db:pull": "cd packages/db && prisma db pull",
    "test": "npm run test --workspace=apps/api",
    "lint": "npm run lint --workspaces --if-present",
    "prepare": "husky"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
